# ─── Flask ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-flask-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-in-prod
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
# DB_TYPE=mysql  → uses MySQL via PyMySQL (production)
# DB_TYPE=sqlite → uses SQLite file (development default)
DB_TYPE=sqlite
DB_PATH=secureauth.db

# MySQL / MariaDB — only needed when DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=secureauth_db
DB_USER=secureauth_user
DB_PASSWORD=SecurePass123!

# ─── MFA / Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
MFA_FROM_EMAIL=noreply@yourdomain.com
OTP_EXPIRY_MINUTES=5

# ─── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=20
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
