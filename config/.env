# ─── Database ────────────────────────────────────────────────────────────────
# DB_TYPE=mysql  → uses MySQL via PyMySQL (production)
# DB_TYPE=postgres → uses PostgreSQL (Supabase / Neon)
# DB_TYPE=sqlite → uses SQLite file (development default)
DB_TYPE=postgres
DB_PATH=secureauth.db
# On Vercel, relative SQLite paths are automatically moved to /tmp.

# MySQL / MariaDB — only needed when DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=secureauth_db
DB_USER=secureauth_user
DB_PASSWORD=SecurePass123!

